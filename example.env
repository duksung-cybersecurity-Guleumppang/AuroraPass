# 단일 서버 배포를 위한 환경 변수 예시
# 이 파일을 .env 파일로 복사하고 필요에 따라 값을 업데이트하세요.
# 값은 반드시 변경해서 사용해주세요.

# Backend auth (for /api/users/login)
LOGIN_USERNAME=demo_user
LOGIN_PASSWORD=demo_password

# Ports
BACKEND_PORT=8000
FRONT_PORT=3000

# PostgreSQL (docker-compose service name 'postgres')
DATABASE_URL=postgresql+psycopg2://appuser:apppass@postgres:5432/aurora

# Redis (docker-compose service name 'redis')
REDIS_URL=redis://redis:6379/0

# CAPTCHA Top-up Scheduler Settings
INVENTORY_TARGET=10
TOP_UP_INTERVAL_SEC=60
MAX_PER_TICK=200
BATCH_SIZE=50
