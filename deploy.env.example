# AWS 배포용 환경변수 설정 파일
# 사용법: 값을 채운 후 deploy.env로 복사하여 사용

# AWS 계정 정보
AWS_REGION=ap-northeast-2
ACCOUNT_ID=123456789012

# ECR 레지스트리 (자동 구성됨)
ECR_REGISTRY=${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# 배포할 이미지 태그 (Git SHA 또는 버전)
IMAGE_TAG=latest

# 데이터베이스 연결 정보 (RDS 엔드포인트)
DATABASE_URL=postgresql+psycopg2://username:password@aurora-postgres.abc123.ap-northeast-2.rds.amazonaws.com:5432/aurora

# Redis 연결 정보 (ElastiCache 엔드포인트)
REDIS_URL=redis://aurora-redis.abc123.cache.amazonaws.com:6379/0

# 로그인 정보 (옵션)
LOGIN_USERNAME=admin
LOGIN_PASSWORD=secure_password_here
